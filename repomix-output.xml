        case 'reveal':
          await window.electronAPI.files.reveal(filePath);
          addNotification(
            `Revealed: ${filePath.split(/[\\/]/).pop()}`,
            'success',
            2000,
            'file-actions',
          );
          break;
        case 'delete': {
          const fileName = filePath.split(/[\\/]/).pop();
          const confirmDelete = await showConfirm({
            title: 'Delete File',
            message:
              'This action cannot be undone. Are you sure you want to permanently delete this file?',
            confirmText: 'Delete',
            cancelText: 'Cancel',
            variant: 'danger',
            fileName,
          });
          if (confirmDelete) {
            const result = await window.electronAPI.files.delete(filePath);
            if (result.success) {
              setAnalysisResults((prev) =>
                prev.filter((f) => f.path !== filePath),
              );
              setSelectedFiles((prev) =>
                prev.filter((f) => f.path !== filePath),
              );
              setFileStates((prev) => {
                if (!prev) return prev;
                const next = { ...prev };
                delete next[filePath];
                return next;
              });
              addNotification(
                `Deleted: ${fileName}`,
                'success',
