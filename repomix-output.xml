          type: 'spreadsheet',
          category: 'Financial',
        },
        {
          name: 'presentation.pptx',
          type: 'presentation',
          category: 'Business',
        },
      ];

      for (const file of testFiles) {
        const filePath = await mockFileSystem.createTestFile(
          file.name,
