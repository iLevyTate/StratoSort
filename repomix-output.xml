        // Return metrics directly for preload validation compatibility
        return metrics;
      } catch (error) {
        logger.error('Failed to collect system metrics:', error);
        return { error: error.message };
      }
    }),
  );

  // Apply update (if downloaded)
  ipcMain.handle(
    IPC_CHANNELS.SYSTEM.APPLY_UPDATE,
