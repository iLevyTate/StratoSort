  schemas,
} = require('./withErrorLogging');

function registerSmartFoldersIpc({
  ipcMain,
  IPC_CHANNELS,
  logger,
  systemAnalytics,
  getCustomFolders,
  setCustomFolders,
  saveCustomFolders,
  buildOllamaOptions,
  getOllamaModel,
