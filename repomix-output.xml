        })
      : withErrorLogging(
          logger,
          async (event, filePath) => {
            try {
              await shell.openPath(filePath);
              logger.info('[FILE-OPS] Opened file:', filePath);
              return { success: true };
            } catch (error) {
              logger.error('[FILE-OPS] Error opening file:', error);
              return { success: false, error: error.message };
            }
          },
          systemAnalytics,
        ),
