          return result;
        } catch (error) {
          logger.error(`[DEBUG-FRAMEWORK] Failed to load module ${request}:`, error);
          this.logDebugEvent('native-module-load-error', {
            module: request,
            error: error.message,
            stack: error.stack,
          });
