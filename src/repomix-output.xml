                <div>
                  ✅{' '}
                  <strong>
                    {unprocessedFiles.filter((f) => f.analysis).length}
                  </strong>{' '}
                  files ready to organize
                </div>
                {unprocessedFiles.filter((f) => !f.analysis).length > 0 && (
                  <div>
                    ⚠️{' '}
                    <strong>
                      {unprocessedFiles.filter((f) => !f.analysis).length}
