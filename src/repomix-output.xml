      return true;
    }),
  );

  ipcMain.handle(
    IPC_CHANNELS.WINDOW.UNMAXIMIZE,
    withErrorLogging(logger, async () => {
      const win = getMainWindow();
      if (win && !win.isDestroyed()) win.unmaximize();
      return true;
