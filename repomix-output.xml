    @apply text-xs text-system-gray-500 transition-all duration-200 opacity-0;
  }

  .floating-label-input:focus ~ .input-hint,
  .floating-label-input:not(:placeholder-shown) ~ .input-hint {
    @apply opacity-100 translate-y-0;
  }

  .input-hint.error {
