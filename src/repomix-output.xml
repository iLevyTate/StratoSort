              imageSize: item.payload.imageBase64?.length || 0,
            },
          );

          item.reject(err);
        } finally {
          q.running--;
          process.nextTick(() => processImgQueue());
        }
      };

      const resp = await enqueueImg({
        model,
        prompt,
