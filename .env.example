# Example environment configuration for StratoSort
# Base URL for the local Ollama AI service
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default multimodal model to use when analyzing images or video
OLLAMA_MULTIMODAL_MODEL=llava

# Set to "true" to always open DevTools when running the Electron app
FORCE_DEV_TOOLS=false
