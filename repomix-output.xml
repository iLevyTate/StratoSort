      expect(mockClient.generate).toHaveBeenCalledWith({
        model: 'test-model',
        prompt: expect.stringContaining('AVAILABLE SMART FOLDERS'),
        options: expect.any(Object),
        format: 'json',
      });
    });

    test('filters invalid smart folders', async () => {
