                  </div>
                </div>
              </div>
            )}
          </div>
          <UndoRedoToolbar className="flex-shrink-0" />
        </div>
      </div>
      {smartFolders.length > 0 && (
        <Collapsible
          title="📁 Target Smart Folders"
          defaultOpen={false}
